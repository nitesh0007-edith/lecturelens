# Copy to .env and fill in your real values

# Qdrant Cloud (free tier) — https://cloud.qdrant.io
QDRANT_URL=https://<cluster-id>.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=lecturelens

# LLM — Groq free tier — https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# LLM fallback — Gemini Flash free tier — https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Storage (relative to working directory)
DATA_DIR=data
WORKSPACE_DATA_DIR=data/workspaces
BM25_INDEX_DIR=data/bm25_indexes
SQLITE_DB=data/lecturelens.db

# Retrieval tuning
BM25_TOP_K=30
DENSE_TOP_K=30
RRF_K=60
RERANK_TOP_K=6

# Rate limiting
RATE_LIMIT_PER_MINUTE=20
